{
  "manifest_version": 3,
  "name": "ProxyXT",
  "version": "1.0.2",
  "description": "Cliente proxy para Chrome y Firefox con multiples servidores y cambio rapido.",
  "permissions": ["storage", "proxy"],
  "optional_permissions": ["tabs"],
  "icons": {
    "16": "icons/proxyxt-16.png",
    "32": "icons/proxyxt-32.png",
    "48": "icons/proxyxt-48.png",
    "128": "icons/proxyxt-128.png"
  },
  "action": {
    "default_title": "ProxyXT",
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/proxyxt-16.png",
      "32": "icons/proxyxt-32.png",
      "48": "icons/proxyxt-48.png",
      "128": "icons/proxyxt-128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "browser_specific_settings": {
    "gecko": {
      "id": "proxyxt@example.local"
    }
  }
}
